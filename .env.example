# Variables de entorno globales

# Modelo de Ollama
# MODEL_NAME=llama3
MODEL_NAME=qwen2.5:3b

# Selección de target: cambia este valor y listo.
#   metasploitable -> tfm_metasploitable @ 172.28.0.10
#   vacaciones     -> tfm_vacaciones     @ 172.28.0.11
#
# TARGET_IP se deriva automáticamente en docker-compose.yml.
# Para Vacaciones, antes del primer `up`: bash scripts/load_vacaciones.sh
# COMPOSE_PROFILES=metasploitable
COMPOSE_PROFILES=metasploitable
